{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cloak",
  "version": "0.1.0",
  "identifier": "io.cloak.gui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cloak",
        "label": "main",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "fullscreen": false,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "copyright": "Copyright 2026 The Cloak Authors",
    "shortDescription": "Local secret broker",
    "longDescription": "Cloak keeps real credentials inside an encrypted local vault and exposes each one as a local network endpoint that speaks the credential's native protocol.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
